<!-- ═══════════════════════════════
     PAGE 1: INQUIRIES
═══════════════════════════════ -->
<div class="page" id="page-1">
  <div class="page-header">
    <div><h2>Inquiries</h2><p>All buyer submissions from your contact form</p></div>
    <select id="inq-filter" class="filter-sel" onchange="filterInq()">
      <option value="">All Status</option>  
      <option value="new">🟡 New</option>
      <option value="contacted">🔵 Contacted</option>
      <option value="closed">🟢 Closed</option>
    </select>
  </div>

  <% if(inquiries.length===0){ %>
    <div class="tbl-card"><div class="empty"><div class="e-ico">📬</div><p>No inquiries received yet.</p></div></div>
  <% } else { %>
  <div class="tbl-card">
    <div class="tbl-head">
      <div>
        <h3>All Inquiries</h3>
        <p><%= inquiries.length %> total &nbsp;·&nbsp; <%= inquiries.filter(i=>i.status==='new').length %> new</p>
      </div>
    </div>
    <table>
      <thead>
        <tr>
          <th>Buyer</th>
          <th>Message</th>
          <th>Date</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% inquiries.forEach(function(inq){ %>
        <tr data-status="<%= inq.status %>">
          <td>
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--blue),#60a5fa);display:flex;align-items:center;justify-content:center;font-size:.9rem;font-weight:800;color:#fff;flex-shrink:0;">
                <%= inq.name ? inq.name.charAt(0).toUpperCase() : '?' %>
              </div>
              <div>
                <div style="font-weight:600;font-size:.88rem;color:var(--text);"><%= inq.name %></div>
                <a href="mailto:<%= inq.email %>" style="font-size:.75rem;color:var(--blue);text-decoration:none;"><%= inq.email %></a>
              </div>
            </div>
          </td>
          <td style="max-width:180px;font-size:.8rem;color:var(--muted);">
            <%= (inq.message||'').substring(0,50) %><%= (inq.message||'').length>50?'…':'' %>
          </td>
          <td style="font-size:.78rem;color:var(--muted);white-space:nowrap;">
            <%= new Date(inq.createdAt).toLocaleDateString('en-IN') %>
          </td>
          <td>
            <form action="/admin/inquiries/<%= inq._id %>/status" method="POST">
              <select name="status" class="status-sel" onchange="this.form.submit()">
                <option value="new"       <%= inq.status==='new'?'selected':'' %>>🟡 New</option>
                <option value="contacted" <%= inq.status==='contacted'?'selected':'' %>>🔵 Contacted</option>
                <option value="closed"    <%= inq.status==='closed'?'selected':'' %>>🟢 Closed</option>
              </select>
            </form>
          </td>
          <td>
            <div class="actions">
              <!-- VIEW -->
              <button class="act-btn act-view" title="View"
                data-name="<%= inq.name %>"
                data-email="<%= inq.email %>"
                data-msg="<%= encodeURIComponent(inq.message||'') %>"
                data-date="<%= new Date(inq.createdAt).toLocaleString('en-IN') %>"
                data-status="<%= inq.status %>"
                onclick="viewInquiry(this)">
                <i class="fa fa-eye"></i>
              </button>
              <!-- DELETE -->
              <form action="/admin/inquiries/<%= inq._id %>/delete" method="POST" style="display:inline;">
                <button type="submit" class="act-btn act-del" title="Delete"
                  onclick="return confirm('Delete this inquiry from <%= inq.name %>?')">
                  <i class="fa fa-trash"></i>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- INQUIRY VIEW MODAL -->
<div class="overlay" id="inq-overlay">
  <div class="modal">
    <div class="modal-head">
      <h3>Inquiry Details</h3>
      <button class="modal-close" onclick="closeOverlay('inq-overlay')">×</button>
    </div>
    <div class="modal-body">
      <div class="inq-top">
        <div class="inq-avatar" id="iv-av">?</div>
        <div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.1rem;font-weight:800;color:var(--text);" id="iv-name">—</div>
          <a id="iv-email" href="#" style="font-size:.84rem;color:var(--blue);text-decoration:none;">—</a>
        </div>
        <div style="margin-left:auto;" id="iv-badge"></div>
      </div>
      <div class="inq-detail-grid">
        <div class="inq-field"><div class="if-lbl">📅 Submitted On</div><div class="if-val" id="iv-date">—</div></div>
        <div class="inq-field"><div class="if-lbl">📊 Status</div><div class="if-val" id="iv-status">—</div></div>
      </div>
      <p class="view-sect">Message</p>
      <div class="inq-msg" id="iv-msg">—</div>
    </div>
    <div class="modal-foot">
      <button class="btn-ghost" onclick="closeOverlay('inq-overlay')">Close</button>
    </div>
  </div>
</div>


