<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Domania — Admin Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg:        #f0f6ff;
      --white:     #ffffff;
      --blue:      #2563eb;
      --blue-light:#eff6ff;
      --blue-mid:  #dbeafe;
      --blue-dark: #1d4ed8;
      --text:      #1e293b;
      --muted:     #64748b;
      --border:    #e2eaf4;
      --danger:    #ef4444;
      --shadow:    0 4px 24px rgba(37,99,235,0.10);
    }

    body {
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', sans-serif;
      position: relative;
      overflow: hidden;
    }

    /* soft background blobs */
    body::before {
      content: '';
      position: fixed;
      width: 700px; height: 700px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(37,99,235,0.08) 0%, transparent 65%);
      top: -200px; right: -200px;
      pointer-events: none;
    }
    body::after {
      content: '';
      position: fixed;
      width: 500px; height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(37,99,235,0.06) 0%, transparent 65%);
      bottom: -150px; left: -150px;
      pointer-events: none;
    }

    .split {
      display: flex;
      width: 900px;
      max-width: 96vw;
      background: var(--white);
      border-radius: 24px;
      box-shadow: 0 20px 60px rgba(37,99,235,0.12);
      overflow: hidden;
      position: relative;
      z-index: 1;
      animation: fadeUp .5s ease both;
    }
    @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }

    /* LEFT PANEL */
    .left {
      flex: 1;
      background: linear-gradient(145deg, #2563eb 0%, #1e40af 60%, #1e3a8a 100%);
      padding: 52px 44px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
    }
    .left::before {
      content: '';
      position: absolute;
      width: 300px; height: 300px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
      top: -80px; right: -80px;
    }
    .left::after {
      content: '';
      position: absolute;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: rgba(255,255,255,0.04);
      bottom: -60px; left: -60px;
    }
    .left-logo {
      display: flex; align-items: center; gap: 12px; position: relative; z-index: 1;
    }
    .left-logo-icon {
      width: 48px; height: 48px;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; border: 1px solid rgba(255,255,255,0.2);
    }
    .left-logo h1 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.5rem; font-weight: 800; color: #fff;
    }
    .left-logo p { font-size: .72rem; color: rgba(255,255,255,.6); margin-top: 1px; letter-spacing: .5px; }

    .left-content { position: relative; z-index: 1; }
    .left-content h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.9rem; font-weight: 800; color: #fff;
      line-height: 1.3; margin-bottom: 16px;
    }
    .left-content p { font-size: .88rem; color: rgba(255,255,255,.7); line-height: 1.7; }

    .left-features { position: relative; z-index: 1; }
    .feat-item {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 12px; font-size: .83rem; color: rgba(255,255,255,.85);
    }
    .feat-dot {
      width: 22px; height: 22px; border-radius: 50%;
      background: rgba(255,255,255,.15); display: flex; align-items: center; justify-content: center;
      font-size: .7rem; flex-shrink: 0;
    }

    /* RIGHT PANEL */
    .right {
      width: 400px;
      padding: 52px 44px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .right h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.5rem; font-weight: 800; color: var(--text);
      margin-bottom: 6px;
    }
    .right .sub { font-size: .84rem; color: var(--muted); margin-bottom: 32px; }

    .err-box {
      background: #fef2f2; border: 1px solid #fecaca;
      color: var(--danger); padding: 11px 14px;
      border-radius: 10px; font-size: .82rem;
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 20px;
    }

    .field { margin-bottom: 18px; }
    .field label {
      display: block; font-size: .73rem; font-weight: 600;
      color: var(--muted); letter-spacing: .6px;
      text-transform: uppercase; margin-bottom: 7px;
    }
    .field input {
      width: 100%;
      background: var(--blue-light);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      padding: 12px 16px;
      font-family: 'Inter', sans-serif;
      font-size: .9rem; color: var(--text);
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .field input:focus {
      border-color: var(--blue);
      background: #fff;
      box-shadow: 0 0 0 3px rgba(37,99,235,.1);
    }
    .field input::placeholder { color: #94a3b8; }

    .btn-login {
      width: 100%;
      background: linear-gradient(135deg, var(--blue), var(--blue-dark));
      color: #fff; border: none; border-radius: 10px;
      padding: 13px; font-family: 'Inter', sans-serif;
      font-size: .92rem; font-weight: 600; cursor: pointer;
      letter-spacing: .2px; margin-top: 6px;
      box-shadow: 0 4px 16px rgba(37,99,235,.3);
      transition: transform .2s, box-shadow .2s;
    }
    .btn-login:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(37,99,235,.35); }

    @media (max-width: 700px) {
      .left { display: none; }
      .right { width: 100%; padding: 40px 28px; }
    }
  </style>
</head>
<body>
<div class="split">
  <!-- Left -->
  <div class="left">
    <div class="left-logo">
      <div class="left-logo-icon">🌐</div>
      <div>
        <h1>Domania</h1>
        <p>Admin Panel</p>
      </div>
    </div>
    <div class="left-content">
      <h2>Manage Your Domain Portfolio</h2>
      <p>Add, edit, and track your premium domains. View all inquiries and visitor analytics from one place.</p>
    </div>
    <div class="left-features">
      <div class="feat-item"><div class="feat-dot">🌐</div> Manage domain listings</div>
      <div class="feat-item"><div class="feat-dot">📬</div> Track buyer inquiries</div>
      <div class="feat-item"><div class="feat-dot">👁️</div> Visitor analytics</div>
    </div>
  </div>

  <!-- Right -->
  <div class="right">
    <h2>Welcome back</h2>
    <p class="sub">Sign in to your admin dashboard</p>

    <% if (error) { %>
    <div class="err-box">⚠ <%= error %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="field">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="admin@domania.com" required autofocus />
      </div>
      <div class="field">
        <label>Password</label>
        <input type="password" name="password" placeholder="Enter your password" required />
      </div>
      <button type="submit" class="btn-login">Sign In →</button>
    </form>
  </div>
</div>
</body>
</html>
